{
  "name": "@kazeful/lazy-tooltip",
  "version": "0.0.0",
  "packageManager": "pnpm@8.2.0",
  "description": "Lazy tooltip component for vue.js 2-3",
  "author": "kazeful",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazeful/lazy-tooltip"
  },
  "bugs": "https://github.com/kazeful/lazy-tooltip/issues",
  "keywords": [
    "starter",
    "boilerplate",
    "vue",
    "vue3",
    "component",
    "ui",
    "frontend"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.umd.js",
      "import": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite --port 3333 --open",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "release": "bumpp && npm publish",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "up": "taze major -I",
    "postinstall": "npx simple-git-hooks"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.7.1",
    "vue": "^2.0.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "^9.13.0",
    "vue-demi": "^0.13.11",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.38.4",
    "@iconify-json/carbon": "^1.1.16",
    "@types/node": "^18.15.11",
    "@unocss/eslint-config": "^0.51.4",
    "@unocss/reset": "^0.51.4",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vue-macros/volar": "^0.9.5",
    "@vue/test-utils": "^2.3.2",
    "bumpp": "^8.2.1",
    "eslint": "^8.38.0",
    "jsdom": "^21.1.1",
    "lint-staged": "^13.2.1",
    "pnpm": "^8.2.0",
    "simple-git-hooks": "^2.8.1",
    "taze": "^0.9.1",
    "typescript": "^5.0.4",
    "unocss": "^0.51.4",
    "unplugin-auto-import": "^0.15.2",
    "unplugin-vue-components": "^0.24.1",
    "unplugin-vue-macros": "^2.0.0",
    "vite": "^4.2.1",
    "vite-plugin-pages": "^0.29.0",
    "vitest": "^0.30.1",
    "vue": "^3.2.47",
    "vue-tsc": "^1.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "eslintConfig": {
    "extends": [
      "@antfu",
      "@unocss"
    ]
  }
}
